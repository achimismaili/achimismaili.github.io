# === Secrets & credentials (NEVER commit) =====================================
# Note: root .npmrc is intentionally tracked (registry config). Auth tokens
# belong in ~/.npmrc or in CI as env vars. See WebSites/docs/operations/secrets.md.

# Token-bearing variants of package-manager configs
.npmrc.local
**/.npmrc.local
.yarnrc.local
.yarnrc.yml.local
.netrc

# Keys & certificates
*.pem
*.key
*.pfx
*.p12
*.cer
*.crt
*.der
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
*.ppk

# Cloud provider credentials
.aws/credentials
.azure/credentials
.azure/accessTokens.json
.azure/azureProfile.json
gcloud-key.json
**/service-account*.json
**/local.settings.json

# Terraform (state may contain plaintext secrets)
*.tfvars
!*.tfvars.example
!*.tfvars.sample
*.tfstate
*.tfstate.*
.terraform/

# Secrets by convention
secrets.json
secrets.yml
secrets.yaml
*.secrets.json
*.secret

# Editor backups (could mirror secret content)
*.bak
*~

# Sisyphus orchestration — transient state & QA artifacts (plans stay tracked)
.sisyphus/boulder.json
.sisyphus/evidence/
.sisyphus/screenshots/
.sisyphus/notepads/

# Playwright MCP working directory
.playwright-mcp/
