---
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import Base from '../layouts/Base.astro';
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import Prose from '@achimismaili/easy-web-content-blocks/components/Prose';
import { getCollection, render } from 'astro:content';

const entries = await getCollection('pages', (e) =>
  e.data.translationKey === 'contact' && e.data.locale === 'de'
);
const entry = entries[0];
const { Content } = entry ? await render(entry) : { Content: () => null };
---

<Base
  lang="de"
  title={entry?.data.title ?? 'Kontakt'}
  pathname="/kontakt/"
  alternateHref="/en/contact/"
  description={entry?.data.description}
>
  {entry && <Prose><Content /></Prose>}
</Base>
