---
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import Base from '../../layouts/Base.astro';
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import GalleryLightboxGrid from '@achimismaili/easy-web-content-blocks/components/GalleryLightboxGrid';
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import CtaSection from '@achimismaili/easy-web-content-blocks/components/CtaSection';

const works = [
  { src: '/images/gallery/hero-demo.svg', alt: 'Projekt Eins', title: 'Projekt Eins', description: 'Eine kurze Beschreibung des ersten Projekts.' },
  { src: '/images/gallery/cards-demo.svg', alt: 'Projekt Zwei', title: 'Projekt Zwei', description: 'Eine kurze Beschreibung des zweiten Projekts.' },
  { src: '/images/gallery/theme-demo.svg', alt: 'Projekt Drei', title: 'Projekt Drei', description: 'Eine kurze Beschreibung des dritten Projekts.' },
  { src: '/images/gallery/cards-demo.svg', alt: 'Projekt Vier', title: 'Projekt Vier', description: 'Eine kurze Beschreibung des vierten Projekts.' },
  { src: '/images/gallery/hero-demo.svg', alt: 'Projekt Fünf', title: 'Projekt Fünf', description: 'Eine kurze Beschreibung des fünften Projekts.' },
  { src: '/images/gallery/theme-demo.svg', alt: 'Projekt Sechs', title: 'Projekt Sechs', description: 'Eine kurze Beschreibung des sechsten Projekts.' },
];
---

<Base
  lang="de"
  title="Vorlage — Portfolio"
  pathname="/templates/portfolio/"
  alternateHref="/en/templates/portfolio/"
  description="Vorschau der Portfolio-Startseiten-Vorlage."
>
  <section class="ew-tpl-portfolio-hero">
    <img
      class="ew-tpl-portfolio-hero__bg"
      src="/images/gallery/hero-demo.svg"
      alt=""
      aria-hidden="true"
    />
    <div class="ew-tpl-portfolio-hero__overlay"></div>
    <div class="ew-tpl-portfolio-hero__content">
      <p class="ew-tpl-portfolio-hero__eyebrow">Vorlage: portfolio</p>
      <h1 class="ew-tpl-portfolio-hero__title">Studio Beispiel</h1>
      <p class="ew-tpl-portfolio-hero__subtitle">
        Ausgewählte Arbeiten aus Design, Entwicklung und visueller Gestaltung.
      </p>
    </div>
  </section>

  <section class="ew-tpl-portfolio-about">
    <div class="ew-tpl-portfolio-about__inner">
      <h2>Über das Studio</h2>
      <p>
        Wir arbeiten an visuellen Identitäten, digitalen Produkten und
        gedruckten Editionen. Diese Auswahl zeigt einen Querschnitt unserer
        jüngsten Projekte.
      </p>
    </div>
  </section>

  <GalleryLightboxGrid
    title="Ausgewählte Arbeiten"
    columns={3}
    gap="md"
    aspectRatio="square"
    items={works}
  />

  <CtaSection
    heading="Sie haben ein Projekt?"
    body="Schreiben Sie uns — wir freuen uns auf neue Herausforderungen."
    buttonLabel="Kontakt aufnehmen"
    buttonHref="mailto:hello@example.com"
    variant="primary"
  />
</Base>

<style>
  .ew-tpl-portfolio-hero {
    position: relative;
    min-height: 28rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ew-tpl-portfolio-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .ew-tpl-portfolio-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.7));
    z-index: 1;
  }
  .ew-tpl-portfolio-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: var(--ew-space-7) var(--ew-space-5);
    max-width: 56rem;
  }
  .ew-tpl-portfolio-hero__eyebrow {
    font-family: var(--ew-font-mono);
    font-size: var(--ew-text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.7;
    margin: 0 0 var(--ew-space-3);
  }
  .ew-tpl-portfolio-hero__title {
    font-family: var(--ew-font-sans);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0 0 var(--ew-space-4);
  }
  .ew-tpl-portfolio-hero__subtitle {
    font-family: var(--ew-font-sans);
    font-size: clamp(1rem, 2.2vw, 1.25rem);
    line-height: var(--ew-leading-normal);
    margin: 0;
    opacity: 0.95;
  }

  .ew-tpl-portfolio-about {
    padding: var(--ew-space-8) var(--ew-space-5);
  }
  .ew-tpl-portfolio-about__inner {
    max-width: 45rem;
    margin: 0 auto;
    text-align: center;
  }
  .ew-tpl-portfolio-about h2 {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-xl);
    font-weight: 700;
    color: var(--ew-on-surface);
    margin: 0 0 var(--ew-space-4);
    line-height: var(--ew-leading-tight);
  }
  .ew-tpl-portfolio-about p {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-base);
    color: var(--ew-on-surface);
    margin: 0;
    line-height: var(--ew-leading-loose);
  }
</style>
