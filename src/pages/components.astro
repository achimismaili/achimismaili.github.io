---
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import Base from '../layouts/Base.astro';
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import GallerySection from '@achimismaili/easy-web-content-blocks/components/GallerySection';
import { getEntry } from 'astro:content';

const heroSliderEntry = await getEntry('galleries', 'de/home-hero');
const imageGridEntry = await getEntry('galleries', 'de/about-component-preview');
const carouselEntry = await getEntry('galleries', 'de/showcase-carousel');
const masonryEntry = await getEntry('galleries', 'de/showcase-masonry');
const featuresEntry = await getEntry('galleries', 'de/showcase-features');
const lightboxEntry = await getEntry('galleries', 'de/showcase-lightbox');

const sections = [
  {
    kind: 'hero-slider',
    title: 'Hero-Slider',
    description: 'Großformatiger editorialer Slider mit Titel, Untertitel und optionalem CTA pro Folie. Ideal als oberster Abschnitt einer Landingpage.',
    entry: heroSliderEntry,
  },
  {
    kind: 'image-grid',
    title: 'Bildraster',
    description: 'Statisches N-Spalten-Raster mit gleicher Bildgröße. Geeignet für Komponenten-Vorschauen, Team-Fotos oder Sponsoren.',
    entry: imageGridEntry,
  },
  {
    kind: 'carousel',
    title: 'Karussell',
    description: 'Bilder-Slider mit optionalen Bildunterschriften. Begrenzte Breite, kein CTA pro Folie — für Galerien innerhalb einer Seite.',
    entry: carouselEntry,
  },
  {
    kind: 'masonry-grid',
    title: 'Mosaik-Raster',
    description: 'Pinterest-artiges Raster mit variabler Bildhöhe via CSS-Spalten. Geeignet für Fotografie und Portfolios.',
    entry: masonryEntry,
  },
  {
    kind: 'feature-highlight',
    title: 'Funktions-Hervorhebung',
    description: 'Abwechselnde Bild-und-Text-Reihen mit optionalem CTA. Geeignet für Produkt-Features oder Service-Beschreibungen.',
    entry: featuresEntry,
  },
  {
    kind: 'lightbox-grid',
    title: 'Lightbox-Raster',
    description: 'Einheitliches Raster mit Klick-zur-Vollansicht-Modal. Tastatur-Navigation: Esc schließt, Pfeiltasten wechseln. Für Foto-Alben.',
    entry: lightboxEntry,
  },
];
---

<Base
  lang="de"
  title="Komponenten — Galerie-Varianten"
  pathname="/components/"
  alternateHref="/en/components/"
  description="Übersicht aller verfügbaren Galerie-Komponenten im easy-web-Ökosystem."
>
  <article class="ew-components-intro">
    <div class="ew-components-intro__inner">
      <h1>Galerie-Komponenten</h1>
      <p>
        Übersicht aller sechs Galerie-Varianten im easy-web-Ökosystem. Jede Variante
        wird über ein <code>kind</code>-Feld in den CMS-Einträgen unter
        <code>src/content/galleries/</code> ausgewählt und über
        <code>&lt;GallerySection /&gt;</code> in Seiten eingebunden.
      </p>
    </div>
  </article>

  {sections.map((s, i) => (
    <article class="ew-components-section" id={s.kind}>
      <div class="ew-components-section__header">
        <h2>{i + 1}. {s.title} <code>({s.kind})</code></h2>
        <p>{s.description}</p>
      </div>
      <GallerySection entry={s.entry} />
    </article>
  ))}
</Base>

<style>
  .ew-components-intro {
    padding: var(--ew-space-8) var(--ew-space-5) 0;
  }
  .ew-components-intro__inner {
    max-width: 45rem;
    margin: 0 auto;
  }
  .ew-components-intro h1 {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-3xl);
    font-weight: 700;
    color: var(--ew-on-surface);
    margin: 0 0 var(--ew-space-4);
    line-height: var(--ew-leading-tight);
  }
  .ew-components-intro p {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-base);
    color: var(--ew-on-surface);
    margin: 0;
    line-height: var(--ew-leading-loose);
  }
  .ew-components-intro code {
    font-family: var(--ew-font-mono);
    font-size: 0.9em;
    background: var(--ew-surface-muted);
    border-radius: var(--ew-radius-sm);
    padding: 0.15em 0.35em;
  }

  .ew-components-section {
    border-top: 1px solid var(--ew-border);
    margin-top: var(--ew-space-7);
  }
  .ew-components-section:first-of-type {
    border-top: none;
    margin-top: var(--ew-space-7);
  }

  .ew-components-section__header {
    padding: var(--ew-space-7) var(--ew-space-5) 0;
    max-width: 72rem;
    margin: 0 auto;
  }
  .ew-components-section__header h2 {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-xl);
    font-weight: 700;
    color: var(--ew-on-surface);
    margin: 0 0 var(--ew-space-3);
    line-height: var(--ew-leading-tight);
  }
  .ew-components-section__header h2 code {
    font-family: var(--ew-font-mono);
    font-size: 0.75em;
    color: var(--ew-muted);
    font-weight: 400;
    background: var(--ew-surface-muted);
    border-radius: var(--ew-radius-sm);
    padding: 0.15em 0.4em;
    margin-left: var(--ew-space-2);
  }
  .ew-components-section__header p {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-base);
    color: var(--ew-muted);
    margin: 0;
    line-height: var(--ew-leading-normal);
    max-width: 45rem;
  }
</style>
