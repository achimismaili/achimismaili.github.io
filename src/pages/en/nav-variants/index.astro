---
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import Base from '../../../layouts/Base.astro';

const variants = [
  {
    slug: 'classic',
    title: 'Classic',
    description: 'The standard header with sticky behaviour. Navigation on the left, actions on the right. The slot system allows a custom action bar.',
    notes: 'Fallback: ThemeToggle + LanguageSwitch',
  },
  {
    slug: 'centered',
    title: 'Centered',
    description: 'Brand name centered, navigation links split left and right. Ideal for symmetrical layouts.',
    notes: 'Same props and slot as Classic',
  },
  {
    slug: 'hide-on-scroll',
    title: 'Hide on Scroll',
    description: 'Header slides off screen when scrolling down and reappears when scrolling up. Uses position: fixed with body padding compensation.',
    notes: 'Scroll direction + requestAnimationFrame',
  },
  {
    slug: 'flyout',
    title: 'Flyout',
    description: 'Nav items with children[] show a dropdown panel on hover (desktop) and click (mobile). Fully keyboard accessible.',
    notes: 'aria-expanded, aria-haspopup, Esc to close',
  },
];
---

<Base
  lang="en"
  title="Nav Variants — Header Variants"
  pathname="/en/nav-variants/"
  alternateHref="/nav-variants/"
  description="Overview of the four header variants of the slot system."
>
  <article class="ew-nav-variants-intro">
    <div class="ew-nav-variants-intro__inner">
      <h1>Header Variants</h1>
      <p>
        Four structural header variants built on the <code>actions</code> slot.
        Each variant supports the same props set and gives instances full control
        over the action bar — from ThemeToggle and LanguageSwitch to auth buttons
        or any Astro component.
      </p>
    </div>
  </article>

  <section class="ew-nav-variants-grid-section">
    <div class="ew-nav-variants-grid">
      {variants.map((v) => (
        <a class="ew-variant-card" href={`/en/nav-variants/${v.slug}/`}>
          <div class="ew-variant-card__body">
            <p class="ew-variant-card__slug"><code>{v.slug}</code></p>
            <h2 class="ew-variant-card__title">{v.title}</h2>
            <p class="ew-variant-card__description">{v.description}</p>
            <p class="ew-variant-card__notes"><strong>Note:</strong> {v.notes}</p>
            <span class="ew-variant-card__cta">View demo →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .ew-nav-variants-intro {
    padding: var(--ew-space-8) var(--ew-space-5) 0;
  }
  .ew-nav-variants-intro__inner {
    max-width: 45rem;
    margin: 0 auto;
  }
  .ew-nav-variants-intro h1 {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-3xl);
    font-weight: 700;
    color: var(--ew-on-surface);
    margin: 0 0 var(--ew-space-4);
    line-height: var(--ew-leading-tight);
  }
  .ew-nav-variants-intro p {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-base);
    color: var(--ew-on-surface);
    margin: 0;
    line-height: var(--ew-leading-loose);
  }
  .ew-nav-variants-intro code {
    background: var(--ew-surface-muted);
    border-radius: var(--ew-radius-sm);
    padding: 0.15em 0.35em;
  }

  .ew-nav-variants-grid-section {
    padding: var(--ew-space-7) var(--ew-space-5) var(--ew-space-9);
  }
  .ew-nav-variants-grid {
    max-width: 72rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ew-space-5);
  }
  @media (min-width: 768px) {
    .ew-nav-variants-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .ew-variant-card {
    display: flex;
    flex-direction: column;
    background: var(--ew-surface);
    border: 1px solid var(--ew-border);
    border-radius: var(--ew-radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .ew-variant-card:hover,
  .ew-variant-card:focus-visible {
    border-color: var(--ew-primary);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
  }
  .ew-variant-card:focus-visible {
    outline: 2px solid var(--ew-primary);
    outline-offset: 2px;
  }
  .ew-variant-card__body {
    padding: var(--ew-space-5);
    display: flex;
    flex-direction: column;
    gap: var(--ew-space-2);
  }
  .ew-variant-card__slug code {
    font-family: var(--ew-font-mono);
    font-size: var(--ew-text-xs);
    color: var(--ew-muted);
    background: var(--ew-surface-muted);
    border-radius: var(--ew-radius-sm);
    padding: 0.15em 0.4em;
  }
  .ew-variant-card__title {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-xl);
    font-weight: 700;
    color: var(--ew-on-surface);
    margin: 0;
    line-height: var(--ew-leading-tight);
  }
  .ew-variant-card__description {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-base);
    color: var(--ew-on-surface);
    margin: 0;
    line-height: var(--ew-leading-normal);
  }
  .ew-variant-card__notes {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-sm);
    color: var(--ew-muted);
    margin: 0;
    line-height: var(--ew-leading-normal);
  }
  .ew-variant-card__cta {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-base);
    font-weight: 600;
    color: var(--ew-primary);
    margin-top: var(--ew-space-2);
  }
</style>
