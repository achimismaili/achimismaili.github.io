---
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import Base from '../../layouts/Base.astro';
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import Hero from '@achimismaili/easy-web-content-blocks/components/Hero';
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import Section from '@achimismaili/easy-web-content-blocks/components/Section';
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import CardGrid from '@achimismaili/easy-web-content-blocks/components/CardGrid';
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import Card from '@achimismaili/easy-web-content-blocks/components/Card';
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import CtaSection from '@achimismaili/easy-web-content-blocks/components/CtaSection';
import { getEntry } from 'astro:content';

const homeData = await getEntry('siteConfig', 'home-en');
const { page, hero, featuresSection, features, ctaSection } = homeData!.data as any;
---

<Base
  lang="en"
  title={page.title}
  pathname="/en/"
  description={page.description}
>
  <Hero
    title={hero.title}
    subtitle={hero.subtitle}
    ctaLabel={hero.ctaLabel}
    ctaHref={hero.ctaHref}
  />

  <Section title={featuresSection.title}>
    <CardGrid>
      {features.map((f: { title: string; description: string }) => (
        <Card title={f.title} description={f.description} />
      ))}
    </CardGrid>
  </Section>

  <CtaSection
    heading={ctaSection.heading}
    body={ctaSection.body}
    buttonLabel={ctaSection.buttonLabel}
    buttonHref={ctaSection.buttonHref}
    variant={ctaSection.variant}
  />
</Base>
