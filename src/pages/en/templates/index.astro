---
// biome-ignore lint/correctness/noUnusedImports: used in the Astro template below.
import Base from '../../../layouts/Base.astro';

const templates = [
  {
    slug: 'classic-landing',
    title: 'Classic Landing',
    description: 'Hero, features, CTA — the classic landing page. Suited to software, services, and products.',
    bestFor: 'SaaS, products, services',
    img: '/images/gallery/cards-demo.svg',
  },
  {
    slug: 'magazine',
    title: 'Magazine',
    description: 'Featured post on top, followed by a grid of recent posts. Suited to blogs and editorial sites.',
    bestFor: 'Blogs, editorial, news',
    img: '/images/gallery/hero-demo.svg',
  },
  {
    slug: 'portfolio',
    title: 'Portfolio',
    description: 'Image-driven layout with a lightbox gallery and short about text. Suited to creatives and agencies.',
    bestFor: 'Creatives, agencies, photographers',
    img: '/images/gallery/theme-demo.svg',
  },
  {
    slug: 'coming-soon',
    title: 'Coming Soon',
    description: 'Full-bleed hero with title and subtitle — minimalist. Suited as a pre-launch placeholder.',
    bestFor: 'Pre-launch, simple brands',
    img: '/images/gallery/hero-demo.svg',
  },
];
---

<Base
  lang="en"
  title="Templates — Homepage Templates"
  pathname="/en/templates/"
  alternateHref="/templates/"
  description="Overview of homepage templates for new instances."
>
  <article class="ew-templates-intro">
    <div class="ew-templates-intro__inner">
      <h1>Homepage Templates</h1>
      <p>
        Four complete homepage layouts that serve as a starting point for a new
        instance. Each template is a self-contained Astro file copied during site
        scaffolding via <code>new-site.ps1</code>. Click any of them below to see
        the template in action.
      </p>
    </div>
  </article>

  <section class="ew-templates-grid-section">
    <div class="ew-templates-grid">
      {templates.map((t) => (
        <a class="ew-template-card" href={`/en/templates/${t.slug}/`}>
          <img src={t.img} alt="" class="ew-template-card__img" loading="lazy" aria-hidden="true" />
          <div class="ew-template-card__body">
            <p class="ew-template-card__slug"><code>{t.slug}</code></p>
            <h2 class="ew-template-card__title">{t.title}</h2>
            <p class="ew-template-card__description">{t.description}</p>
            <p class="ew-template-card__best-for"><strong>Best for:</strong> {t.bestFor}</p>
            <span class="ew-template-card__cta">View preview →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .ew-templates-intro {
    padding: var(--ew-space-8) var(--ew-space-5) 0;
  }
  .ew-templates-intro__inner {
    max-width: 45rem;
    margin: 0 auto;
  }
  .ew-templates-intro h1 {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-3xl);
    font-weight: 700;
    color: var(--ew-on-surface);
    margin: 0 0 var(--ew-space-4);
    line-height: var(--ew-leading-tight);
  }
  .ew-templates-intro p {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-base);
    color: var(--ew-on-surface);
    margin: 0;
    line-height: var(--ew-leading-loose);
  }
  .ew-templates-intro code {
    font-family: var(--ew-font-mono);
    font-size: 0.9em;
    background: var(--ew-surface-muted);
    border-radius: var(--ew-radius-sm);
    padding: 0.15em 0.35em;
  }

  .ew-templates-grid-section {
    padding: var(--ew-space-7) var(--ew-space-5) var(--ew-space-9);
  }
  .ew-templates-grid {
    max-width: 72rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ew-space-5);
  }
  @media (min-width: 768px) {
    .ew-templates-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .ew-template-card {
    display: flex;
    flex-direction: column;
    background: var(--ew-surface);
    border: 1px solid var(--ew-border);
    border-radius: var(--ew-radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .ew-template-card:hover,
  .ew-template-card:focus-visible {
    border-color: var(--ew-primary);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
  }
  .ew-template-card:focus-visible {
    outline: 2px solid var(--ew-primary);
    outline-offset: 2px;
  }
  .ew-template-card__img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }
  .ew-template-card__body {
    padding: var(--ew-space-5);
    display: flex;
    flex-direction: column;
    gap: var(--ew-space-2);
  }
  .ew-template-card__slug code {
    font-family: var(--ew-font-mono);
    font-size: var(--ew-text-xs);
    color: var(--ew-muted);
    background: var(--ew-surface-muted);
    border-radius: var(--ew-radius-sm);
    padding: 0.15em 0.4em;
  }
  .ew-template-card__title {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-xl);
    font-weight: 700;
    color: var(--ew-on-surface);
    margin: 0;
    line-height: var(--ew-leading-tight);
  }
  .ew-template-card__description {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-base);
    color: var(--ew-on-surface);
    margin: 0;
    line-height: var(--ew-leading-normal);
  }
  .ew-template-card__best-for {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-sm);
    color: var(--ew-muted);
    margin: 0;
    line-height: var(--ew-leading-normal);
  }
  .ew-template-card__cta {
    font-family: var(--ew-font-sans);
    font-size: var(--ew-text-base);
    font-weight: 600;
    color: var(--ew-primary);
    margin-top: var(--ew-space-2);
  }
</style>
